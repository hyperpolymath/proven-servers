package proven-ws
version = "0.1.0"
authors = "Jonathan D.A. Jewell"
license = "MPL-2.0"
brief   = "WebSocket server that cannot crash on malformed frames"

sourcedir = "src"
main = Main
executable = "proven-ws"

modules = WS
        , WS.Opcode
        , WS.Frame
        , WS.Handshake
        , WS.CloseCode
        , WS.Session

