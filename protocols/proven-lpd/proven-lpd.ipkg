package proven-lpd
version = "0.1.0"
authors = "Jonathan D.A. Jewell"
license = "MPL-2.0"
brief   = "Line Printer Daemon that cannot crash on malformed print jobs"

sourcedir = "src"
main = Main
executable = "proven-lpd"

modules = LPD
        , LPD.Command
        , LPD.Job
        , LPD.Queue
        , LPD.Protocol
        , LPD.Spool

