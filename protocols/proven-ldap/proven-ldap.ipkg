package proven-ldap
version = "0.1.0"
authors = "Jonathan D.A. Jewell"
license = "MPL-2.0"
brief   = "LDAP client/server with type-safe ASN.1 encoding (RFC 4511)"

sourcedir = "src"
main = Main
executable = "proven-ldap"

modules = LDAP
        , LDAP.Types
        , LDAPABI.Layout
        , LDAPABI.Transitions
        , LDAPABI.Foreign
