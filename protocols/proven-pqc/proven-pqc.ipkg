package proven-pqc
version = "0.1.0"
authors = "Jonathan D.A. Jewell"
license = "MPL-2.0"
brief   = "Post-Quantum Cryptography server with NIST FIPS 203/204/205 algorithms"

sourcedir = "src"
main = Main
executable = "proven-pqc"

modules = PQC
        , PQC.Types
        , PQCABI.Layout
        , PQCABI.Transitions
        , PQCABI.Foreign
        , Main
