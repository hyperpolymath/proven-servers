package proven-wasm
version = "0.1.0"
authors = "Jonathan D.A. Jewell"
license = "MPL-2.0"
brief   = "WebAssembly module builder with verified memory safety"

sourcedir = "src"
main = Main
executable = "proven-wasm"

modules = WASM
        , WASM.ValType
        , WASM.Instruction
        , WASM.Module
        , WASM.Memory
        , WASM.Types

