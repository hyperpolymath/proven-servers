package proven-graphql
version = "0.1.0"
authors = "Jonathan D.A. Jewell"
license = "MPL-2.0"
brief   = "Proven GraphQL server with formally verified ABI"

sourcedir = "src"
main = Main
executable = "proven-graphql"

modules = GraphQL
        , GraphQL.Types
        , GraphQL.Schema
        , GraphQL.Query
        , GraphQL.Introspection
        , GraphQL.Resolver
        , GraphQLABI.Layout
        , GraphQLABI.Transitions
        , GraphQLABI.Foreign
        , Main
