--
-- Dev tool: emits the canonical ABI tag manifest from the proven encoders.
-- Consumed by tools/gen-abi.sh to render agentic_abi_gen.zig.

package proven-agentic-abigen
version = "0.1.0"
authors = "Jonathan D.A. Jewell"
license = "MPL-2.0"
brief   = "ABI tag-manifest emitter for proven-agentic"

sourcedir = "src"
main = AgenticABI.Emit
executable = "agentic-abigen"

modules = Agentic.Types
        , AgenticABI.Layout
        , AgenticABI.Foreign
        , AgenticABI.Emit
