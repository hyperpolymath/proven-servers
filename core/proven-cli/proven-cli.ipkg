package proven-cli
version = "0.1.0"
authors = "Jonathan D.A. Jewell"
license = "MPL-2.0"
brief   = "CLI framework that cannot crash on malformed arguments"

sourcedir = "src"
main = Main
executable = "proven-cli"

modules = CLI
        , CLI.ArgType
        , CLI.Option
        , CLI.Command
        , CLI.Parser
        , CLI.Help

